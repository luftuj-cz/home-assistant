{
  "code": "korado",
  "name": "KORADO VENTBOX",
  "variables": [
    {
      "name": "power",
      "type": "number",
      "editable": true,
      "onDashboard": true,
      "label": { "text": "hru.power", "translate": true },
      "unit": "%",
      "min": 0,
      "max": 100,
      "maxConfigurable": false,
      "step": 5,
      "class": "power"
    },
    {
      "name": "unit_sn",
      "type": "number",
      "editable": false,
      "onDashboard": true,
      "label": { "text": "hru.serialNo", "translate": true }
    },
    {
      "name": "te1",
      "type": "number",
      "editable": false,
      "onDashboard": true,
      "label": "Te1",
      "unit": "˚C",
      "class": "temperature"
    },
    {
      "name": "te1p",
      "type": "number",
      "editable": false,
      "onDashboard": true,
      "label": "Te1p",
      "unit": "˚C",
      "class": "temperature"
    },
    {
      "name": "te2",
      "type": "number",
      "editable": false,
      "onDashboard": true,
      "label": "Te2",
      "unit": "˚C",
      "class": "temperature"
    },
    {
      "name": "ti1",
      "type": "number",
      "editable": false,
      "onDashboard": true,
      "label": "Ti1",
      "unit": "˚C",
      "class": "temperature"
    },
    {
      "name": "ti2",
      "type": "number",
      "editable": false,
      "onDashboard": true,
      "label": "Ti2",
      "unit": "˚C",
      "class": "temperature"
    }
  ],
  "interface-type": "modbus-tcp",
  "integration": {
    "read": [
      {
        "type": "assignment",
        "variable": "$power",
        "value": {
          "function": "modbus_read_input",
          "args": [107, 1]
        }
      },
      {
        "type": "assignment",
        "variable": "$unit_sn",
        "value": {
          "function": "modbus_read_input",
          "args": [100, 1]
        }
      },
      {
        "type": "assignment",
        "variable": "$te1",
        "value": {
          "function": "modbus_read_input",
          "args": [110, 1]
        }
      },
      {
        "type": "assignment",
        "variable": "$te1p",
        "value": {
          "function": "modbus_read_input",
          "args": [111, 1]
        }
      },
      {
        "type": "assignment",
        "variable": "$te2",
        "value": {
          "function": "modbus_read_input",
          "args": [112, 1]
        }
      },
      {
        "type": "assignment",
        "variable": "$ti1",
        "value": {
          "function": "modbus_read_input",
          "args": [113, 1]
        }
      },
      {
        "type": "assignment",
        "variable": "$ti2",
        "value": {
          "function": "modbus_read_input",
          "args": [114, 1]
        }
      }
    ],
    "write": [
      {
        "type": "action",
        "expression": {
          "function": "modbus_write_holding",
          "args": [106, "$power"]
        }
      }
    ],
    "keepAlive": {
      "period": 5000,
      "commands": [
        {
          "type": "action",
          "expression": { "function": "modbus_write_coil", "args": [31, 1] }
        }
      ]
    }
  }
}
